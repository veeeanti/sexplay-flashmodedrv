[Version]
Signature="$WINDOWS NT$"
Provider=%SEMCName%
Class=USB
ClassGuid={36fc9e60-c465-11cf-8056-444553540000}
DriverVer=03/03/2026,1.0.0.0
CatalogFile=SEXPlay-FlashmodeDrv.cat
PnpLockDown=1

[DestinationDirs]
DefaultDestDir = 12
WDFCoInstaller_CopyFiles = 11

[SourceDisksNames.x86]
1 = %InstallationDiskName%,,,\x86

[SourceDisksNames.Amd64]
1 = %InstallationDiskName%,,,\Amd64

[SourceDisksFiles]
SEXPlay-FlashmodeDrv.sys = 1
SEXPlayFlt.sys = 1
WdfCoInstaller01011.dll = 1

[Manufacturer]
%MfgName%=SEMC,NTx86.10,NTAmd64.10,NTx86,NTAmd64

